        { "label": "Inside a kitchen running 22 hours a day",     "next": "q3_setup" }
      ]
    },

    "q1_setup": {
      "type": "video",
      "video": "01_q1_origin.mp4",
      "next": "q1_deep_prompt"
    },
    "q1_deep_prompt": {
      "type": "decision",
      "prompt": "Want to go deeper?",
      "options": [
        { "label": "Why cooking is a love language in Emma's family", "next": "q1_deep" },
        { "label": "Ask a different question",                         "next": "hub" }
      ]
    },
    "q1_deep": {
      "type": "video",
      "video": "02_q1_deep.mp4",
      "next": "close"
    },

    "q2_setup": {
      "type": "video",
      "video": "03_q2_secret_sauce.mp4",
      "next": "close"
    },

    "q3_setup": {
      "type": "video",
      "video": "05_q3_setup.mp4",
      "next": "q3_deep_prompt"
    },
    "q3_deep_prompt": {
      "type": "decision",
      "prompt": "Want to go deeper?",
