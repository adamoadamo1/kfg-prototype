        { "label": "The flywheel the new building unlocks", "next": "close" },
        { "label": "Ask a different question",              "next": "hub" }
      ]
    },

    "close": {
      "type": "video",
      "video": "04_close.mp4",
      "next": "end"
    },

    "end": {
      "type": "decision",
      "prompt": "Want to explore another path?",
      "options": [
        { "label": "Pick a different question", "next": "hub" },
        { "label": "Start over",                "next": "intro" }
